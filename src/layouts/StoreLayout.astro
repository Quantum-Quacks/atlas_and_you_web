---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Atlas&You — Joyería Artesanal', description = 'Joyería artesanal única hecha con arcilla polimérica y resina. Pendientes, colgantes y pulseras.' } = Astro.props;
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="bg-stone-50 text-stone-900 min-h-screen flex flex-col">

  <!-- Navbar -->
  <header class="bg-white border-b border-stone-200 sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <span class="text-2xl font-bold tracking-tight text-stone-900">Atlas<span class="text-amber-700">&You</span></span>
      </a>
      <nav class="hidden md:flex items-center gap-8 text-sm font-medium">
        <a href="/tienda" class="hover:text-amber-700 transition-colors">Tienda</a>
        <a href="/tienda?categoria=pendientes" class="hover:text-amber-700 transition-colors">Pendientes</a>
        <a href="/tienda?categoria=colgantes" class="hover:text-amber-700 transition-colors">Colgantes</a>
        <a href="/tienda?categoria=pulseras" class="hover:text-amber-700 transition-colors">Pulseras</a>
      </nav>
      <div class="flex items-center gap-4">
        <a href="/carrito" class="relative p-2 hover:text-amber-700 transition-colors" id="cart-btn">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
          <span id="cart-count" class="absolute -top-1 -right-1 bg-amber-700 text-white text-xs rounded-full h-5 w-5 flex items-center justify-center hidden">0</span>
        </a>
        <!-- Mobile menu button -->
        <button class="md:hidden p-2" id="mobile-menu-btn">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
    <!-- Mobile nav -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-stone-200 bg-white">
      <nav class="flex flex-col px-4 py-4 gap-4 text-sm font-medium">
        <a href="/tienda" class="hover:text-amber-700">Tienda</a>
        <a href="/tienda?categoria=pendientes" class="hover:text-amber-700">Pendientes</a>
        <a href="/tienda?categoria=colgantes" class="hover:text-amber-700">Colgantes</a>
        <a href="/tienda?categoria=pulseras" class="hover:text-amber-700">Pulseras</a>
      </nav>
    </div>
  </header>

  <main class="flex-1">
    <slot />
  </main>

  <footer class="bg-stone-900 text-stone-300 mt-20">
    <div class="max-w-6xl mx-auto px-4 py-12 grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="text-white font-bold text-lg mb-3">Atlas<span class="text-amber-400">&You</span></h3>
        <p class="text-sm leading-relaxed">Joyería artesanal única, hecha a mano con arcilla polimérica y resina. Cada pieza es irrepetible.</p>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-3">Tienda</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/tienda" class="hover:text-amber-400 transition-colors">Todos los productos</a></li>
          <li><a href="/tienda?categoria=pendientes" class="hover:text-amber-400 transition-colors">Pendientes</a></li>
          <li><a href="/tienda?categoria=colgantes" class="hover:text-amber-400 transition-colors">Colgantes</a></li>
          <li><a href="/tienda?categoria=pulseras" class="hover:text-amber-400 transition-colors">Pulseras</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-3">Información</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/envios" class="hover:text-amber-400 transition-colors">Envíos y devoluciones</a></li>
          <li><a href="/contacto" class="hover:text-amber-400 transition-colors">Contacto</a></li>
          <li><a href="/aviso-legal" class="hover:text-amber-400 transition-colors">Aviso legal</a></li>
          <li><a href="/privacidad" class="hover:text-amber-400 transition-colors">Privacidad</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-stone-800 py-6 text-center text-xs text-stone-500">
      © {new Date().getFullYear()} Atlas&You. Todos los derechos reservados.
    </div>
  </footer>

  <script>
    // Mobile menu toggle
    document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.toggle('hidden');
    });

    // Cart count from localStorage
    function updateCartCount() {
      const cart = JSON.parse(localStorage.getItem('atlas_cart') || '[]');
      const count = cart.reduce((sum: number, item: any) => sum + item.quantity, 0);
      const badge = document.getElementById('cart-count');
      if (badge) {
        badge.textContent = count.toString();
        badge.classList.toggle('hidden', count === 0);
      }
    }
    updateCartCount();
    window.addEventListener('cart-updated', updateCartCount);
  </script>
</body>
</html>
