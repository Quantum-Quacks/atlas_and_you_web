---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Atlas&You — Joyería Artesanal', description = 'Joyería artesanal única hecha con arcilla polimérica y resina. Pendientes, colgantes y pulseras.' } = Astro.props;
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" />
</head>
<body>

  <!-- TOP BAR -->
  <div style="background:#1F6666;color:#fff;font-size:12px;">
    <div style="max-width:1440px;margin:0 auto;padding:7px 24px;display:flex;align-items:center;justify-content:space-between;gap:16px;">
      <div style="display:flex;align-items:center;gap:16px;">
        <a href="/contacto" style="color:rgba(255,255,255,0.85);text-decoration:none;letter-spacing:0.04em;" onmouseenter="this.style.color='#fff'" onmouseleave="this.style.color='rgba(255,255,255,0.85)'">Contacto</a>
        <span style="color:rgba(255,255,255,0.3);">|</span>
        <a href="/envios" style="color:rgba(255,255,255,0.85);text-decoration:none;letter-spacing:0.04em;" onmouseenter="this.style.color='#fff'" onmouseleave="this.style.color='rgba(255,255,255,0.85)'">Envíos y devoluciones</a>
        <span style="color:rgba(255,255,255,0.3);">|</span>
        <span style="color:rgba(255,255,255,0.85);letter-spacing:0.04em;">✦ Envío gratis en España a partir de 50&nbsp;€</span>
      </div>
      <div style="display:flex;align-items:center;gap:14px;">
        <!-- Instagram -->
        <a href="https://instagram.com/atlasandyou" target="_blank" rel="noopener" style="color:rgba(255,255,255,0.85);display:flex;" aria-label="Instagram" onmouseenter="this.style.color='#fff'" onmouseleave="this.style.color='rgba(255,255,255,0.85)'">
          <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
        <!-- TikTok -->
        <a href="#" target="_blank" rel="noopener" style="color:rgba(255,255,255,0.85);display:flex;" aria-label="TikTok" onmouseenter="this.style.color='#fff'" onmouseleave="this.style.color='rgba(255,255,255,0.85)'">
          <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.3 6.3 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.76a4.85 4.85 0 01-1.01-.07z"/></svg>
        </a>
        <!-- Pinterest -->
        <a href="#" target="_blank" rel="noopener" style="color:rgba(255,255,255,0.85);display:flex;" aria-label="Pinterest" onmouseenter="this.style.color='#fff'" onmouseleave="this.style.color='rgba(255,255,255,0.85)'">
          <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
        </a>
      </div>
    </div>
  </div>

  <!-- MAIN HEADER -->
  <header style="background:#fff;border-bottom:1px solid #e8e8e8;padding:14px 24px;">
    <div style="max-width:1440px;margin:0 auto;display:flex;align-items:center;gap:20px;">

      <!-- Logo -->
      <a href="/" style="text-decoration:none;flex-shrink:0;line-height:1;text-align:center;">
        <span style="font-family:'Playfair Display',Georgia,serif;font-weight:700;font-size:20px;color:#2B8080;display:block;letter-spacing:0.02em;">Atlas</span>
        <span style="font-family:'Playfair Display',Georgia,serif;font-weight:400;font-size:10px;color:#2B8080;font-style:italic;display:block;letter-spacing:0.1em;">&amp;</span>
        <span style="font-family:'Playfair Display',Georgia,serif;font-weight:700;font-size:20px;color:#2B8080;display:block;letter-spacing:0.02em;">You</span>
      </a>

      <!-- Search bar -->
      <form method="get" action="/tienda" style="flex:1;display:flex;border:1.5px solid #2B8080;overflow:hidden;max-width:720px;">
        <input
          type="text" name="q"
          placeholder="Buscar productos..."
          style="flex:1;padding:10px 16px;font-size:13px;border:none;outline:none;font-family:'Nunito',sans-serif;background:#fff;"
        />
        <select name="categoria" style="padding:10px 12px;border:none;border-left:1px solid #ddd;background:#f9f9f9;font-size:12px;font-weight:700;outline:none;color:#444;font-family:'Nunito',sans-serif;letter-spacing:0.05em;cursor:pointer;">
          <option value="">CATEGORÍA</option>
          <option value="pendientes">Pendientes</option>
          <option value="colgantes">Colgantes</option>
          <option value="pulseras">Pulseras</option>
        </select>
        <button type="submit" style="background:#2B8080;color:#fff;border:none;padding:10px 18px;cursor:pointer;display:flex;align-items:center;">
          <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </button>
      </form>

      <!-- Actions -->
      <div style="display:flex;align-items:center;gap:6px;flex-shrink:0;">
        <a href="/admin/login" style="font-size:12px;font-weight:700;color:#444;text-decoration:none;padding:8px 12px;white-space:nowrap;letter-spacing:0.03em;" onmouseenter="this.style.color='#2B8080'" onmouseleave="this.style.color='#444'">
          Acceder
        </a>
        <!-- Wishlist -->
        <button style="background:none;border:none;padding:8px;cursor:pointer;color:#444;display:flex;align-items:center;position:relative;" aria-label="Favoritos">
          <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
          </svg>
        </button>
        <!-- Cart -->
        <a href="/carrito" id="cart-btn" style="display:flex;align-items:center;gap:8px;padding:8px 14px;background:#2B8080;color:#fff;text-decoration:none;font-size:13px;font-weight:700;" aria-label="Carrito">
          <span style="position:relative;">
            <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
            </svg>
            <span id="cart-count" style="display:none;position:absolute;top:-6px;right:-6px;background:#E85D04;color:#fff;font-size:9px;font-weight:800;border-radius:50%;width:16px;height:16px;align-items:center;justify-content:center;">0</span>
          </span>
          <span id="cart-total" style="white-space:nowrap;">0,00 €</span>
        </a>
        <!-- Mobile hamburger -->
        <button id="mobile-menu-btn" class="mobile-only" style="padding:8px;background:none;border:none;cursor:pointer;color:#2d2d2d;" aria-label="Menú">
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <!-- SECONDARY NAV -->
  <nav style="background:#fff;border-bottom:2px solid #e8e8e8;" class="secondary-nav">
    <div style="max-width:1440px;margin:0 auto;display:flex;align-items:stretch;">
      <!-- Catalog button -->
      <a href="/tienda" style="background:#2B8080;color:#fff;padding:0 22px;font-size:12px;font-weight:800;text-decoration:none;display:flex;align-items:center;gap:10px;letter-spacing:0.08em;white-space:nowrap;">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        NUESTRO CATÁLOGO
      </a>
      <!-- Nav links -->
      <div style="display:flex;align-items:stretch;overflow-x:auto;" class="nav-links">
        {[
          ['TIENDA', '/tienda'],
          ['PENDIENTES', '/tienda?categoria=pendientes'],
          ['COLGANTES', '/tienda?categoria=colgantes'],
          ['PULSERAS', '/tienda?categoria=pulseras'],
          ['NOVEDADES', '/tienda'],
        ].map(([label, href]) => (
          <a href={href}
            style="padding:14px 18px;font-size:11px;font-weight:800;color:#333;text-decoration:none;white-space:nowrap;letter-spacing:0.08em;border-bottom:3px solid transparent;transition:color 0.15s,border-color 0.15s;"
            onmouseenter="this.style.color='#2B8080';this.style.borderBottomColor='#2B8080'"
            onmouseleave="this.style.color='#333';this.style.borderBottomColor='transparent'"
          >{label}</a>
        ))}
      </div>
    </div>
  </nav>

  <!-- Mobile drawer -->
  <div id="mobile-menu" style="display:none;background:#fff;border-bottom:2px solid #e8e8e8;">
    <nav style="padding:20px 24px;display:flex;flex-direction:column;gap:16px;">
      {[
        ['Tienda', '/tienda'],
        ['Pendientes', '/tienda?categoria=pendientes'],
        ['Colgantes', '/tienda?categoria=colgantes'],
        ['Pulseras', '/tienda?categoria=pulseras'],
      ].map(([label, href]) => (
        <a href={href} style="font-size:14px;font-weight:700;color:#2d2d2d;text-decoration:none;letter-spacing:0.04em;">{label}</a>
      ))}
    </nav>
  </div>

  <main>
    <slot />
  </main>

  <!-- FOOTER -->
  <footer style="background:#1F6666;color:#fff;margin-top:64px;">
    <div style="max-width:1440px;margin:0 auto;padding:56px 24px 32px;display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:40px;">

      <div>
        <div style="font-family:'Playfair Display',Georgia,serif;font-weight:700;font-size:22px;color:#fff;margin-bottom:16px;line-height:1.2;">
          Atlas<br/><span style="font-style:italic;font-weight:400;font-size:12px;">&amp;</span><br/>You
        </div>
        <p style="font-size:13px;color:rgba(255,255,255,0.75);line-height:1.7;max-width:220px;">
          Joyería artesanal única hecha a mano con arcilla polimérica y resina.
        </p>
        <div style="margin-top:20px;display:flex;gap:14px;">
          <a href="https://instagram.com/atlasandyou" target="_blank" rel="noopener" style="color:rgba(255,255,255,0.75);" aria-label="Instagram" onmouseenter="this.style.color='#fff'" onmouseleave="this.style.color='rgba(255,255,255,0.75)'">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
        </div>
      </div>

      <div>
        <h5 style="font-size:11px;font-weight:800;letter-spacing:0.15em;text-transform:uppercase;color:#fff;margin-bottom:16px;">Tienda</h5>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px;">
          {[['Todos los productos','/tienda'],['Pendientes','/tienda?categoria=pendientes'],['Colgantes','/tienda?categoria=colgantes'],['Pulseras','/tienda?categoria=pulseras']].map(([l,h]) => (
            <li><a href={h} style="font-size:13px;color:rgba(255,255,255,0.75);text-decoration:none;" onmouseenter="this.style.color='#fff'" onmouseleave="this.style.color='rgba(255,255,255,0.75)'">{l}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h5 style="font-size:11px;font-weight:800;letter-spacing:0.15em;text-transform:uppercase;color:#fff;margin-bottom:16px;">Información</h5>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px;">
          {[['Envíos y devoluciones','/envios'],['Guía de cuidados','/cuidados'],['Aviso legal','/aviso-legal'],['Privacidad','/privacidad']].map(([l,h]) => (
            <li><a href={h} style="font-size:13px;color:rgba(255,255,255,0.75);text-decoration:none;" onmouseenter="this.style.color='#fff'" onmouseleave="this.style.color='rgba(255,255,255,0.75)'">{l}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h5 style="font-size:11px;font-weight:800;letter-spacing:0.15em;text-transform:uppercase;color:#fff;margin-bottom:16px;">Contacto</h5>
        <p style="font-size:13px;color:rgba(255,255,255,0.75);line-height:1.8;">
          <a href="/contacto" style="color:rgba(255,255,255,0.75);text-decoration:none;" onmouseenter="this.style.color='#fff'" onmouseleave="this.style.color='rgba(255,255,255,0.75)'">Escríbenos</a><br/>
          <span style="font-size:12px;">Respondemos en &lt; 24 h</span>
        </p>
      </div>
    </div>

    <div style="border-top:1px solid rgba(255,255,255,0.15);padding:18px 24px;text-align:center;font-size:12px;color:rgba(255,255,255,0.5);">
      © {new Date().getFullYear()} Atlas&amp;You — Joyería artesanal hecha en España
    </div>
  </footer>

  <style>
    body { font-family: 'Nunito', sans-serif; background: #f5f5f5; color: #2d2d2d; margin: 0; }
    @media (max-width: 767px) {
      .secondary-nav { display: none !important; }
      .desktop-only { display: none !important; }
      .mobile-only { display: flex !important; }
    }
    @media (min-width: 768px) {
      .mobile-only { display: none !important; }
      .desktop-only { display: flex !important; }
    }
  </style>

  <script>
    document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
      const m = document.getElementById('mobile-menu');
      if (m) m.style.display = m.style.display === 'none' ? 'block' : 'none';
    });

    function updateCartUI() {
      const cart = JSON.parse(localStorage.getItem('atlas_cart') || '[]');
      const count = cart.reduce((s: number, i: any) => s + i.quantity, 0);
      const total = cart.reduce((s: number, i: any) => s + i.price * i.quantity, 0);
      const badge = document.getElementById('cart-count') as HTMLElement;
      const totalEl = document.getElementById('cart-total') as HTMLElement;
      if (badge) {
        badge.textContent = count.toString();
        badge.style.display = count > 0 ? 'flex' : 'none';
      }
      if (totalEl) {
        totalEl.textContent = total.toFixed(2).replace('.', ',') + ' €';
      }
    }
    updateCartUI();
    window.addEventListener('cart-updated', updateCartUI);
  </script>

</body>
</html>
