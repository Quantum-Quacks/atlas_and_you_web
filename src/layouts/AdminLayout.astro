---
import '../styles/global.css';

interface Props {
  title?: string;
  currentPage?: string;
}

const { title = 'Panel Admin — Atlas&You', currentPage = '' } = Astro.props;

const nav = [
  { href: '/admin', label: 'Dashboard', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6', key: 'dashboard' },
  { href: '/admin/pedidos', label: 'Pedidos', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', key: 'pedidos' },
  { href: '/admin/productos', label: 'Productos', icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4', key: 'productos' },
  { href: '/admin/clientes', label: 'Clientes', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z', key: 'clientes' },
  { href: '/admin/envios', label: 'Envíos', icon: 'M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4', key: 'envios' },
  { href: '/admin/descuentos', label: 'Descuentos', icon: 'M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z', key: 'descuentos' },
  { href: '/admin/impuestos', label: 'Impuestos', icon: 'M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z', key: 'impuestos' },
  { href: '/admin/configuracion', label: 'Configuración', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z', key: 'configuracion' },
];
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="bg-stone-100 min-h-screen flex">

  <!-- Sidebar -->
  <aside class="w-64 bg-stone-900 text-stone-300 flex flex-col min-h-screen fixed left-0 top-0">
    <div class="p-6 border-b border-stone-800">
      <a href="/" target="_blank" class="text-xl font-bold text-white">
        Atlas<span class="text-amber-400">&You</span>
      </a>
      <p class="text-xs text-stone-500 mt-1">Panel de Administración</p>
    </div>

    <nav class="flex-1 p-4 space-y-1">
      {nav.map(item => (
        <a
          href={item.href}
          class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${
            currentPage === item.key
              ? 'bg-amber-700 text-white'
              : 'hover:bg-stone-800 hover:text-white'
          }`}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon} />
          </svg>
          {item.label}
        </a>
      ))}
    </nav>

    <div class="p-4 border-t border-stone-800">
      <a href="/admin/logout" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm hover:bg-stone-800 hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
        </svg>
        Cerrar sesión
      </a>
    </div>
  </aside>

  <!-- Main content -->
  <div class="ml-64 flex-1 flex flex-col min-h-screen">
    <header class="bg-white border-b border-stone-200 px-8 h-16 flex items-center justify-between">
      <h1 class="text-lg font-semibold text-stone-800">{title.replace(' — Atlas&You', '')}</h1>
      <div class="flex items-center gap-4">
        <a href="/tienda" target="_blank" class="text-sm text-stone-500 hover:text-amber-700 transition-colors">
          Ver tienda →
        </a>
      </div>
    </header>
    <main class="flex-1 p-8">
      <slot />
    </main>
  </div>

</body>
</html>
