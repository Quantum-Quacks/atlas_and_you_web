---
import StoreLayout from '../layouts/StoreLayout.astro';
import ProductCard from '../components/storefront/ProductCard.astro';
import { getDb, IS_MOCK } from '../lib/firebase-admin';
import { mockProducts, mockCategories } from '../lib/mock-data';

let featured: any[] = [];
let categories: any[] = [];

if (IS_MOCK) {
  featured = mockProducts.filter(p => p.featured);
  categories = mockCategories;
} else {
  const db = getDb();
  const [featSnap, catSnap] = await Promise.all([
    db.collection('products').where('active','==',true).where('featured','==',true).limit(8).get(),
    db.collection('categories').where('active','==',true).orderBy('position').get(),
  ]);
  featured = featSnap.docs.map(d => ({ id: d.id, ...d.data() }));
  categories = catSnap.docs.map(d => ({ id: d.id, ...d.data() }));
}
---

<StoreLayout title="Atlas&You — Joyería Artesanal Hecha a Mano">

  <!-- ── HERO ─────────────────────────────────────────────────── -->
  <section style="position:relative;overflow:hidden;min-height:65vh;display:flex;flex-direction:column;align-items:center;justify-content:center;">
    <!-- Background image -->
    <img
      src="/images/products/peces-turquesa-lifestyle-1.jpg"
      alt="Atlas&You joyería artesanal"
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;"
    />
    <!-- Overlay -->
    <div style="position:absolute;inset:0;background:rgba(0,0,0,0.48);"></div>

    <!-- Content -->
    <div style="position:relative;z-index:1;text-align:center;padding:60px 32px 40px;">
      <h1 style="font-family:'Playfair Display',Georgia,serif;font-weight:700;font-size:clamp(2.8rem,7vw,5.5rem);color:#fff;margin:0 0 12px;line-height:1.05;letter-spacing:-0.01em;">
        Joyería Artesanal
      </h1>
      <p style="font-size:clamp(14px,2vw,18px);color:rgba(255,255,255,0.8);margin:0 0 40px;font-weight:400;letter-spacing:0.02em;">
        Hecha a mano en España · Arcilla polimérica y resina
      </p>
      <!-- Category links -->
      <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:10px;">
        {[
          ['PENDIENTES', '/tienda?categoria=pendientes'],
          ['COLGANTES', '/tienda?categoria=colgantes'],
          ['PULSERAS', '/tienda?categoria=pulseras'],
          ['VER TODO', '/tienda'],
        ].map(([label, href]) => (
          <a href={href}
            style="display:inline-flex;align-items:center;padding:10px 22px;font-family:'Nunito',sans-serif;font-size:12px;font-weight:800;letter-spacing:0.12em;color:#fff;border:1.5px solid rgba(255,255,255,0.7);text-decoration:none;transition:all 0.2s;background:rgba(0,0,0,0.15);"
            onmouseenter="this.style.background='#2B8080';this.style.borderColor='#2B8080'"
            onmouseleave="this.style.background='rgba(0,0,0,0.15)';this.style.borderColor='rgba(255,255,255,0.7)'"
          >{label}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── VALUES STRIP ──────────────────────────────────────────── -->
  <div style="background:#fff;border-bottom:1px solid #e8e8e8;">
    <div style="max-width:1440px;margin:0 auto;">
      <div class="values-strip">
        {[
          ['🤲', 'Hecho a mano', 'Cada pieza, única'],
          ['✦', 'Sin alérgenos', 'Materiales hipoalergénicos'],
          ['📦', 'Envío gratis', 'En España desde 50 €'],
          ['↩', 'Devoluciones', '14 días garantizados'],
        ].map(([icon, label, sub]) => (
          <div style="padding:16px 20px;text-align:center;border-right:1px solid #e8e8e8;">
            <span style="font-size:18px;display:block;margin-bottom:4px;">{icon}</span>
            <p style="font-size:12px;font-weight:800;color:#1a1a1a;margin:0 0 2px;letter-spacing:0.04em;text-transform:uppercase;">{label}</p>
            <p style="font-size:11px;color:#888;margin:0;">{sub}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ── FEATURED PRODUCTS ─────────────────────────────────────── -->
  {featured.length > 0 && (
    <section style="max-width:1440px;margin:0 auto;padding:56px 24px 64px;">
      <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:32px;">
        <div>
          <p style="font-size:11px;font-weight:800;letter-spacing:0.15em;text-transform:uppercase;color:#2B8080;margin-bottom:6px;">Selección</p>
          <h2 style="font-family:'Playfair Display',Georgia,serif;font-weight:700;font-size:clamp(1.8rem,3.5vw,2.6rem);color:#1a1a1a;margin:0;">Más Vendidos</h2>
        </div>
        <a href="/tienda"
          style="font-size:12px;font-weight:800;letter-spacing:0.08em;text-transform:uppercase;color:#2B8080;text-decoration:none;border-bottom:2px solid #2B8080;padding-bottom:2px;"
          onmouseenter="this.style.color='#1F6666';this.style.borderBottomColor='#1F6666'"
          onmouseleave="this.style.color='#2B8080';this.style.borderBottomColor='#2B8080'"
        >Ver todo →</a>
      </div>

      <div class="products-grid">
        {featured.map((product: any) => <ProductCard product={product} />)}
      </div>
    </section>
  )}

  <!-- ── COLLECTIONS BANNER ────────────────────────────────────── -->
  {categories.length > 0 && (
    <section style="background:#fff;padding:56px 0;border-top:1px solid #e8e8e8;border-bottom:1px solid #e8e8e8;">
      <div style="max-width:1440px;margin:0 auto;padding:0 24px;">
        <div style="text-align:center;margin-bottom:36px;">
          <p style="font-size:11px;font-weight:800;letter-spacing:0.15em;text-transform:uppercase;color:#2B8080;margin-bottom:8px;">Explorar</p>
          <h2 style="font-family:'Playfair Display',Georgia,serif;font-weight:700;font-size:clamp(1.8rem,3.5vw,2.6rem);color:#1a1a1a;margin:0;">Nuestras Colecciones</h2>
        </div>
        <div class="collections-grid">
          {categories.slice(0,3).map((cat: any, i: number) => (
            <a href={`/tienda?categoria=${cat.slug}`}
              style={`display:block;position:relative;overflow:hidden;text-decoration:none;aspect-ratio:${i === 0 ? '3/4' : '4/3'};background:#e8f4f4;`}
              class="collection-tile"
            >
              {cat.image_url ? (
                <img src={cat.image_url} alt={cat.name} style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:transform 0.6s ease;" class="collection-img"/>
              ) : (
                <div style={`position:absolute;inset:0;background:${i===0?'linear-gradient(160deg,#b2d8d8,#1F6666)':i===1?'linear-gradient(160deg,#d4e8e8,#2B8080)':'linear-gradient(160deg,#c8e0e0,#256868)'};`}></div>
              )}
              <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.55) 0%,transparent 55%);"></div>
              <div style="position:absolute;bottom:0;left:0;right:0;padding:24px 20px;">
                <h3 style="font-family:'Playfair Display',Georgia,serif;font-weight:700;font-size:1.5rem;color:#fff;margin:0 0 4px;">{cat.name}</h3>
                <span style="font-size:11px;font-weight:800;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.75);">Descubrir →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── MAKER STORY ───────────────────────────────────────────── -->
  <section style="max-width:1440px;margin:0 auto;padding:64px 24px;">
    <div class="story-grid">
      <div style="position:relative;">
        <div style="aspect-ratio:4/5;overflow:hidden;background:#e8f4f4;">
          <img
            src="/images/products/peces-turquesa-modelo-2.jpg"
            alt="Atlas&You — joyería hecha a mano"
            style="width:100%;height:100%;object-fit:cover;object-position:center top;"
          />
        </div>
        <div style="position:absolute;bottom:-14px;right:-14px;width:70px;height:70px;background:#2B8080;z-index:-1;"></div>
      </div>
      <div style="display:flex;flex-direction:column;justify-content:center;">
        <p style="font-size:11px;font-weight:800;letter-spacing:0.15em;text-transform:uppercase;color:#2B8080;margin-bottom:14px;">Sobre Nosotras</p>
        <h2 style="font-family:'Playfair Display',Georgia,serif;font-weight:700;font-size:clamp(1.8rem,3.5vw,2.6rem);color:#1a1a1a;margin:0 0 20px;line-height:1.2;">
          Artesanía hecha<br/>con alma
        </h2>
        <p style="font-size:14px;color:#555;line-height:1.75;margin-bottom:16px;">
          Cada pieza de Atlas&amp;You nace de la pasión por crear algo completamente único. Trabajamos con arcilla polimérica, resina y pan de oro para dar vida a joyas que cuentan historias.
        </p>
        <p style="font-size:14px;color:#555;line-height:1.75;margin-bottom:32px;">
          No hay dos piezas iguales. Lo que tienes en tus manos es completamente irrepetible — como tú.
        </p>
        <a href="/tienda"
          style="align-self:flex-start;display:inline-flex;align-items:center;gap:8px;background:#2B8080;color:#fff;font-size:12px;font-weight:800;letter-spacing:0.1em;text-transform:uppercase;padding:13px 28px;text-decoration:none;transition:background 0.2s;"
          onmouseenter="this.style.background='#1F6666'"
          onmouseleave="this.style.background='#2B8080'"
        >Descubrir la colección →</a>
      </div>
    </div>
  </section>

</StoreLayout>

<style>
  .values-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }
  .products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .collections-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  .story-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: center;
  }
  .collection-tile:hover .collection-img { transform: scale(1.04); }

  @media (max-width: 960px) {
    .products-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .collections-grid { grid-template-columns: repeat(2, 1fr); }
    .story-grid { grid-template-columns: 1fr; gap: 40px; }
    .values-strip { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 540px) {
    .collections-grid { grid-template-columns: 1fr; }
    .values-strip { grid-template-columns: 1fr; }
  }
</style>
