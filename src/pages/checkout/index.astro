---
import StoreLayout from '../../layouts/StoreLayout.astro';
---

<StoreLayout title="Pago seguro — Atlas&You">
  <div class="max-w-5xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold text-stone-900 mb-8">Finalizar pedido</h1>

    <div class="grid md:grid-cols-5 gap-8">
      <!-- Formulario -->
      <div class="md:col-span-3 space-y-6">
        <!-- Datos de contacto -->
        <div class="bg-white rounded-2xl border border-stone-200 p-6">
          <h2 class="font-bold text-stone-900 mb-5">Datos de contacto</h2>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1">Nombre</label>
              <input type="text" id="first-name" required class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" />
            </div>
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1">Apellidos</label>
              <input type="text" id="last-name" required class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" />
            </div>
            <div class="col-span-2">
              <label class="block text-sm font-medium text-stone-700 mb-1">Email</label>
              <input type="email" id="email" required class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" />
            </div>
            <div class="col-span-2">
              <label class="block text-sm font-medium text-stone-700 mb-1">Teléfono</label>
              <input type="tel" id="phone" class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" />
            </div>
          </div>
        </div>

        <!-- Dirección de envío -->
        <div class="bg-white rounded-2xl border border-stone-200 p-6">
          <h2 class="font-bold text-stone-900 mb-5">Dirección de envío</h2>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-stone-700 mb-1">Dirección</label>
              <input type="text" id="street" required placeholder="Calle, número, piso..." class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" />
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-stone-700 mb-1">Código postal</label>
                <input type="text" id="postal-code" required class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" />
              </div>
              <div>
                <label class="block text-sm font-medium text-stone-700 mb-1">Ciudad</label>
                <input type="text" id="city" required class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" />
              </div>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-stone-700 mb-1">Provincia</label>
                <input type="text" id="province" class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" />
              </div>
              <div>
                <label class="block text-sm font-medium text-stone-700 mb-1">País</label>
                <select id="country" class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500">
                  <option value="ES">España</option>
                  <option value="PT">Portugal</option>
                  <option value="FR">Francia</option>
                  <option value="DE">Alemania</option>
                  <option value="IT">Italia</option>
                  <option value="GB">Reino Unido</option>
                  <option value="OTHER">Otro país</option>
                </select>
              </div>
            </div>
          </div>
        </div>

        <!-- Método de envío -->
        <div class="bg-white rounded-2xl border border-stone-200 p-6">
          <h2 class="font-bold text-stone-900 mb-5">Método de envío</h2>
          <div id="shipping-options" class="space-y-3">
            <p class="text-stone-400 text-sm">Introduce tu dirección para ver las opciones de envío disponibles</p>
          </div>
        </div>

        <!-- Notas -->
        <div class="bg-white rounded-2xl border border-stone-200 p-6">
          <h2 class="font-bold text-stone-900 mb-3">Notas del pedido <span class="font-normal text-stone-400">(opcional)</span></h2>
          <textarea id="notes" rows="3" placeholder="Instrucciones especiales para el pedido..." class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500 resize-none"></textarea>
        </div>
      </div>

      <!-- Resumen del pedido -->
      <div class="md:col-span-2">
        <div class="bg-white rounded-2xl border border-stone-200 p-6 sticky top-24">
          <h2 class="font-bold text-stone-900 text-lg mb-5">Tu pedido</h2>

          <div id="order-items" class="space-y-3 mb-6"></div>

          <div class="border-t border-stone-200 pt-4 space-y-2 text-sm">
            <div class="flex justify-between">
              <span class="text-stone-500">Subtotal</span>
              <span id="checkout-subtotal" class="font-medium">—</span>
            </div>
            <div id="discount-row" class="hidden flex justify-between text-green-600">
              <span>Descuento</span>
              <span id="checkout-discount">—</span>
            </div>
            <div class="flex justify-between">
              <span class="text-stone-500">Envío</span>
              <span id="checkout-shipping" class="font-medium">—</span>
            </div>
            <div class="flex justify-between">
              <span class="text-stone-500">IVA (incluido)</span>
              <span id="checkout-tax" class="font-medium">—</span>
            </div>
            <div class="border-t border-stone-200 pt-3 flex justify-between font-bold text-stone-900 text-base">
              <span>Total</span>
              <span id="checkout-total">—</span>
            </div>
          </div>

          <p id="checkout-error" class="text-red-500 text-sm mt-4 hidden"></p>

          <button
            id="pay-btn"
            class="mt-6 w-full bg-stone-900 hover:bg-stone-800 disabled:bg-stone-300 disabled:cursor-not-allowed text-white font-semibold py-4 rounded-xl transition-colors"
          >
            Pagar con Stripe
          </button>

          <div class="flex items-center justify-center gap-2 mt-4 text-xs text-stone-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
            Pago 100% seguro con Stripe
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const TAX_RATE = 0.21;
    let selectedShippingRateId: string | null = null;
    let selectedShippingCost = 0;

    function getCart() {
      return JSON.parse(localStorage.getItem('atlas_cart') || '[]');
    }

    function formatPrice(n: number) {
      return n.toFixed(2).replace('.', ',') + '€';
    }

    function renderOrderItems() {
      const cart = getCart();
      if (cart.length === 0) {
        window.location.href = '/carrito';
        return;
      }

      const container = document.getElementById('order-items')!;
      container.innerHTML = cart.map((item: any) => `
        <div class="flex gap-3 items-center">
          <img src="${item.image || '/placeholder.jpg'}" alt="${item.name}" class="w-14 h-14 rounded-lg object-cover bg-stone-100" />
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-stone-800 truncate">${item.name}</p>
            <p class="text-xs text-stone-400">Cantidad: ${item.quantity}</p>
          </div>
          <p class="text-sm font-bold text-stone-900">${formatPrice(item.price * item.quantity)}</p>
        </div>
      `).join('');

      updateTotals();
    }

    function updateTotals() {
      const cart = getCart();
      const subtotal = cart.reduce((sum: number, item: any) => sum + item.price * item.quantity, 0);
      const tax = subtotal * TAX_RATE / (1 + TAX_RATE);
      const total = subtotal + selectedShippingCost;

      document.getElementById('checkout-subtotal')!.textContent = formatPrice(subtotal);
      document.getElementById('checkout-tax')!.textContent = formatPrice(tax);
      document.getElementById('checkout-shipping')!.textContent =
        selectedShippingCost === 0 && selectedShippingRateId ? 'Gratis' : selectedShippingRateId ? formatPrice(selectedShippingCost) : 'Por calcular';
      document.getElementById('checkout-total')!.textContent = formatPrice(total);
    }

    // Calcular envío cuando cambia el país
    async function calculateShipping() {
      const country = (document.getElementById('country') as HTMLSelectElement).value;
      const cart = getCart();
      const totalWeight = cart.reduce((sum: number, item: any) => sum + (item.weight_grams || 50) * item.quantity, 0);
      const orderTotal = cart.reduce((sum: number, item: any) => sum + item.price * item.quantity, 0);

      const res = await fetch(`/api/shipping/calculate?country=${country}&weight=${totalWeight}&total=${orderTotal}`);
      const rates = await res.json();

      const container = document.getElementById('shipping-options')!;

      if (!rates.length) {
        container.innerHTML = '<p class="text-stone-400 text-sm">No hay opciones de envío disponibles para tu país</p>';
        return;
      }

      container.innerHTML = rates.map((rate: any) => `
        <label class="flex items-center gap-3 p-3 border border-stone-200 rounded-xl cursor-pointer hover:border-amber-500 transition-colors">
          <input type="radio" name="shipping" value="${rate.id}" data-cost="${rate.rate}" data-name="${rate.name}" class="accent-amber-700" />
          <div class="flex-1">
            <p class="text-sm font-medium text-stone-800">${rate.carrier} — ${rate.name}</p>
            <p class="text-xs text-stone-400">${rate.estimated_days}</p>
          </div>
          <p class="text-sm font-bold text-stone-900">${rate.rate === 0 ? 'Gratis' : formatPrice(rate.rate)}</p>
        </label>
      `).join('');

      // Auto-seleccionar el primero
      const firstRadio = container.querySelector('input[type="radio"]') as HTMLInputElement;
      if (firstRadio) {
        firstRadio.checked = true;
        selectedShippingRateId = firstRadio.value;
        selectedShippingCost = parseFloat(firstRadio.dataset.cost || '0');
        updateTotals();
      }

      container.querySelectorAll('input[type="radio"]').forEach(radio => {
        radio.addEventListener('change', (e) => {
          const r = e.target as HTMLInputElement;
          selectedShippingRateId = r.value;
          selectedShippingCost = parseFloat(r.dataset.cost || '0');
          updateTotals();
        });
      });
    }

    document.getElementById('country')?.addEventListener('change', calculateShipping);

    // Botón de pago
    document.getElementById('pay-btn')?.addEventListener('click', async () => {
      const btn = document.getElementById('pay-btn') as HTMLButtonElement;
      const errorEl = document.getElementById('checkout-error')!;

      const firstName = (document.getElementById('first-name') as HTMLInputElement).value.trim();
      const lastName = (document.getElementById('last-name') as HTMLInputElement).value.trim();
      const email = (document.getElementById('email') as HTMLInputElement).value.trim();
      const street = (document.getElementById('street') as HTMLInputElement).value.trim();
      const city = (document.getElementById('city') as HTMLInputElement).value.trim();
      const postalCode = (document.getElementById('postal-code') as HTMLInputElement).value.trim();
      const province = (document.getElementById('province') as HTMLInputElement).value.trim();
      const country = (document.getElementById('country') as HTMLSelectElement).value;
      const phone = (document.getElementById('phone') as HTMLInputElement).value.trim();
      const notes = (document.getElementById('notes') as HTMLTextAreaElement).value.trim();

      if (!firstName || !lastName || !email || !street || !city || !postalCode) {
        errorEl.textContent = 'Por favor completa todos los campos obligatorios.';
        errorEl.classList.remove('hidden');
        return;
      }

      if (!selectedShippingRateId) {
        errorEl.textContent = 'Por favor selecciona un método de envío.';
        errorEl.classList.remove('hidden');
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Redirigiendo a Stripe...';
      errorEl.classList.add('hidden');

      const cart = getCart();
      const discount = JSON.parse(localStorage.getItem('atlas_discount') || 'null');

      try {
        const res = await fetch('/api/stripe/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            cart,
            shippingRateId: selectedShippingRateId,
            shippingCost: selectedShippingCost,
            customer: { firstName, lastName, email, phone },
            shippingAddress: { name: `${firstName} ${lastName}`, street, city, postalCode, province, country },
            notes,
            discountCode: discount?.code || null,
          }),
        });

        const data = await res.json();

        if (data.url) {
          localStorage.removeItem('atlas_discount');
          window.location.href = data.url;
        } else {
          throw new Error(data.error || 'Error al crear el pago');
        }
      } catch (err: any) {
        errorEl.textContent = err.message || 'Error al procesar el pago. Inténtalo de nuevo.';
        errorEl.classList.remove('hidden');
        btn.disabled = false;
        btn.textContent = 'Pagar con Stripe';
      }
    });

    renderOrderItems();
    calculateShipping();
  </script>
</StoreLayout>
