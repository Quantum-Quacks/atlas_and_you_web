---
import StoreLayout from '../../layouts/StoreLayout.astro';
import { getDb, IS_MOCK } from '../../lib/firebase-admin';
import { mockProducts } from '../../lib/mock-data';

const { slug } = Astro.params;

let product: any = null;
let related: any[] = [];

if (IS_MOCK) {
  product = mockProducts.find(p => p.slug === slug && p.active) || null;
  if (product) {
    related = mockProducts.filter(p => p.category_id === product.category_id && p.id !== product.id && p.active).slice(0, 4);
  }
} else {
  const db = getDb();
  const snap = await db.collection('products').where('slug', '==', slug).where('active', '==', true).limit(1).get();
  if (!snap.empty) {
    const doc = snap.docs[0];
    product = { id: doc.id, ...doc.data() };
    // Cargar categoría
    if (product.category_id) {
      const catDoc = await db.collection('categories').doc(product.category_id).get();
      if (catDoc.exists) product.categories = { id: catDoc.id, ...catDoc.data() };
    }
    // Productos relacionados
    const relSnap = await db.collection('products')
      .where('category_id', '==', product.category_id)
      .where('active', '==', true)
      .limit(5).get();
    related = relSnap.docs
      .map(d => ({ id: d.id, ...d.data() }))
      .filter((p: any) => p.id !== product.id)
      .slice(0, 4);
  }
}

if (!product) return Astro.redirect('/tienda');
---

<StoreLayout title={`${product.name} — Atlas&You`} description={product.description}>
  <div class="max-w-6xl mx-auto px-4 py-10">
    <nav class="flex items-center gap-2 text-sm text-stone-400 mb-8">
      <a href="/" class="hover:text-amber-700">Inicio</a>
      <span>/</span>
      <a href="/tienda" class="hover:text-amber-700">Tienda</a>
      {product.categories && (
        <>
          <span>/</span>
          <a href={`/tienda?categoria=${product.categories.slug}`} class="hover:text-amber-700">{product.categories.name}</a>
        </>
      )}
      <span>/</span>
      <span class="text-stone-700">{product.name}</span>
    </nav>

    <div class="grid md:grid-cols-2 gap-12">
      <div class="space-y-3">
        <div class="aspect-square rounded-2xl overflow-hidden bg-stone-100">
          <img id="main-image" src={product.images?.[0] || 'https://via.placeholder.com/600x600/f5f5f4/a8a29e?text=Atlas%26You'} alt={product.name} class="w-full h-full object-cover" />
        </div>
        {product.images && product.images.length > 1 && (
          <div class="grid grid-cols-4 gap-2">
            {product.images.map((img: string, i: number) => (
              <button class="aspect-square rounded-xl overflow-hidden bg-stone-100 border-2 border-transparent hover:border-amber-600 transition-colors thumbnail-btn" data-src={img}>
                <img src={img} alt={`${product.name} ${i + 1}`} class="w-full h-full object-cover" />
              </button>
            ))}
          </div>
        )}
      </div>

      <div>
        {product.categories && (
          <p class="text-amber-700 text-sm font-medium mb-2">{product.categories.name}</p>
        )}
        <h1 class="text-3xl font-bold text-stone-900 mb-4">{product.name}</h1>

        <div class="flex items-center gap-3 mb-6">
          <span class="text-3xl font-bold text-stone-900">{product.price.toFixed(2)}€</span>
          {product.compare_at_price && product.compare_at_price > product.price && (
            <span class="text-xl text-stone-400 line-through">{product.compare_at_price.toFixed(2)}€</span>
          )}
          <span class="text-sm text-stone-400">IVA incluido</span>
        </div>

        {product.stock === 0 && (
          <p class="text-red-500 font-medium mb-6">Agotado — Consulta disponibilidad</p>
        )}
        {product.stock > 0 && product.stock <= 3 && (
          <p class="text-amber-600 font-medium mb-6">¡Solo quedan {product.stock} unidades!</p>
        )}

        <div class="text-stone-600 text-sm leading-relaxed mb-8">
          <p>{product.description}</p>
        </div>

        {product.tags && product.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-8">
            {product.tags.map((tag: string) => (
              <span class="text-xs bg-stone-100 text-stone-600 px-3 py-1 rounded-full">{tag}</span>
            ))}
          </div>
        )}

        <button
          id="add-to-cart"
          disabled={product.stock === 0}
          data-product={JSON.stringify({ id: product.id, name: product.name, price: product.price, image: product.images?.[0] || '', slug: product.slug, stock: product.stock })}
          class="w-full bg-stone-900 hover:bg-stone-800 disabled:bg-stone-300 disabled:cursor-not-allowed text-white font-semibold py-4 rounded-xl transition-colors text-lg"
        >
          {product.stock === 0 ? 'Agotado' : 'Añadir al carrito'}
        </button>
        <p class="text-xs text-stone-400 text-center mt-3">Envío gratis a partir de 50€ en España</p>

        <div class="mt-8 border-t border-stone-200 pt-8 space-y-3">
          <details class="group">
            <summary class="flex justify-between items-center cursor-pointer text-sm font-medium text-stone-700 py-2">
              Materiales y cuidados <span class="group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <p class="text-sm text-stone-500 mt-2 pb-2">Fabricado artesanalmente con arcilla polimérica de alta calidad. Evitar contacto prolongado con agua y productos químicos.</p>
          </details>
          <details class="group">
            <summary class="flex justify-between items-center cursor-pointer text-sm font-medium text-stone-700 py-2">
              Envíos y devoluciones <span class="group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <p class="text-sm text-stone-500 mt-2 pb-2">Envío en 2-4 días hábiles a España. Devoluciones aceptadas en 14 días desde la recepción en perfecto estado.</p>
          </details>
        </div>
      </div>
    </div>

    {related.length > 0 && (
      <section class="mt-20">
        <h2 class="text-2xl font-bold text-stone-900 mb-8">También te puede gustar</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          {related.map((p: any) => (
            <a href={`/tienda/${p.slug}`} class="group block">
              <div class="aspect-square rounded-xl overflow-hidden bg-stone-100 mb-3">
                <img src={p.images?.[0] || 'https://via.placeholder.com/300'} alt={p.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              </div>
              <h3 class="font-medium text-stone-800 group-hover:text-amber-700 transition-colors text-sm">{p.name}</h3>
              <p class="font-bold text-stone-900 text-sm mt-1">{p.price.toFixed(2)}€</p>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>

  <script>
    document.querySelectorAll('.thumbnail-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const src = (btn as HTMLElement).dataset.src;
        const mainImg = document.getElementById('main-image') as HTMLImageElement;
        if (mainImg && src) mainImg.src = src;
      });
    });
    document.getElementById('add-to-cart')?.addEventListener('click', (e) => {
      const btn = e.currentTarget as HTMLButtonElement;
      const productData = JSON.parse(btn.dataset.product || '{}');
      const cart = JSON.parse(localStorage.getItem('atlas_cart') || '[]');
      const existing = cart.find((item: any) => item.id === productData.id);
      if (existing) { if (existing.quantity < productData.stock) existing.quantity++; }
      else { cart.push({ ...productData, quantity: 1 }); }
      localStorage.setItem('atlas_cart', JSON.stringify(cart));
      window.dispatchEvent(new Event('cart-updated'));
      btn.textContent = '✓ Añadido al carrito';
      btn.classList.add('bg-green-700');
      setTimeout(() => { btn.textContent = 'Añadir al carrito'; btn.classList.remove('bg-green-700'); }, 2000);
    });
  </script>
</StoreLayout>
