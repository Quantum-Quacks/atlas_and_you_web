---
import StoreLayout from '../../layouts/StoreLayout.astro';
import ProductCard from '../../components/storefront/ProductCard.astro';
import { getDb, IS_MOCK } from '../../lib/firebase-admin';
import { mockProducts, mockCategories } from '../../lib/mock-data';

const categoria = Astro.url.searchParams.get('categoria');
const busqueda = Astro.url.searchParams.get('q');

let products: any[] = [];
let categories: any[] = [];

if (IS_MOCK) {
  categories = mockCategories;
  products = mockProducts.filter(p => p.active);
  if (categoria) {
    const cat = mockCategories.find(c => c.slug === categoria);
    if (cat) products = products.filter(p => p.category_id === cat.id);
  }
  if (busqueda) products = products.filter(p => p.name.toLowerCase().includes(busqueda.toLowerCase()));
} else {
  const db = getDb();
  const catSnap = await db.collection('categories').where('active','==',true).orderBy('position').get();
  categories = catSnap.docs.map(d => ({ id: d.id, ...d.data() }));
  let query: any = db.collection('products').where('active','==',true);
  if (categoria) {
    const cat = categories.find((c: any) => c.slug === categoria);
    if (cat) query = query.where('category_id','==',cat.id);
  }
  const prodSnap = await query.orderBy('created_at','desc').get();
  products = prodSnap.docs.map((d: any) => ({ id: d.id, ...d.data() }));
  if (busqueda) products = products.filter(p => p.name.toLowerCase().includes(busqueda.toLowerCase()));
}

const activeCategory = categories.find((c: any) => c.slug === categoria);
const pageTitle = activeCategory ? `${activeCategory.name} — Atlas&You` : 'Tienda Online — Atlas&You';
---

<StoreLayout title={pageTitle}>

  <!-- Hero banner -->
  <section style="position:relative;overflow:hidden;height:300px;display:flex;flex-direction:column;align-items:center;justify-content:center;">
    <img
      src="/images/products/peces-turquesa-lifestyle-2.jpg"
      alt="Tienda Atlas&You"
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 30%;"
    />
    <div style="position:absolute;inset:0;background:rgba(0,0,0,0.5);"></div>
    <div style="position:relative;z-index:1;text-align:center;padding:0 24px;">
      <h1 style="font-family:'Playfair Display',Georgia,serif;font-weight:700;font-size:clamp(2rem,5vw,3.5rem);color:#fff;margin:0 0 20px;line-height:1.05;">
        {activeCategory ? activeCategory.name : 'Tienda Online'}
      </h1>
      <!-- Category pills on hero -->
      <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:8px;">
        {categories.map((cat: any) => (
          <a href={`/tienda?categoria=${cat.slug}`}
            style={`display:inline-flex;align-items:center;padding:7px 18px;font-family:'Nunito',sans-serif;font-size:11px;font-weight:800;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;transition:all 0.15s;${categoria === cat.slug ? 'background:#2B8080;color:#fff;border:1.5px solid #2B8080;' : 'background:rgba(0,0,0,0.2);color:#fff;border:1.5px solid rgba(255,255,255,0.6);'}`}
            onmouseenter={`this.style.background='#2B8080';this.style.borderColor='#2B8080'`}
            onmouseleave={categoria === cat.slug ? '' : `this.style.background='rgba(0,0,0,0.2)';this.style.borderColor='rgba(255,255,255,0.6)'`}
          >{cat.name}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- Controls bar -->
  <div style="background:#fff;border-bottom:1px solid #e8e8e8;position:sticky;top:0;z-index:20;">
    <div style="max-width:1440px;margin:0 auto;padding:12px 24px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;">

      <!-- Breadcrumb + count -->
      <div style="display:flex;align-items:center;gap:12px;">
        <nav style="font-size:12px;color:#888;">
          <a href="/" style="color:#888;text-decoration:none;" onmouseenter="this.style.color='#2B8080'" onmouseleave="this.style.color='#888'">Inicio</a>
          <span style="margin:0 6px;">›</span>
          {activeCategory ? (
            <>
              <a href="/tienda" style="color:#888;text-decoration:none;" onmouseenter="this.style.color='#2B8080'" onmouseleave="this.style.color='#888'">Tienda</a>
              <span style="margin:0 6px;">›</span>
              <span style="color:#1a1a1a;font-weight:700;">{activeCategory.name}</span>
            </>
          ) : (
            <span style="color:#1a1a1a;font-weight:700;">Tienda Online</span>
          )}
        </nav>
        <span style="font-size:12px;color:#aaa;">({products.length} {products.length === 1 ? 'pieza' : 'piezas'})</span>
      </div>

      <!-- Right side: search + grid toggle -->
      <div style="display:flex;align-items:center;gap:12px;">
        <!-- Search inline -->
        <form method="get" action="/tienda" style="display:flex;border:1px solid #e0e0e0;overflow:hidden;">
          {categoria && <input type="hidden" name="categoria" value={categoria} />}
          <input
            type="text" name="q" value={busqueda || ''}
            placeholder="Buscar..."
            style="padding:7px 12px;font-size:12px;border:none;outline:none;width:180px;font-family:'Nunito',sans-serif;"
          />
          <button type="submit" style="background:#2B8080;color:#fff;border:none;padding:7px 12px;cursor:pointer;display:flex;align-items:center;">
            <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          </button>
        </form>
        <!-- All categories link -->
        {categoria && (
          <a href="/tienda" style="font-size:12px;font-weight:700;color:#2B8080;text-decoration:none;white-space:nowrap;border-bottom:1px solid #2B8080;" onmouseenter="this.style.color='#1F6666'" onmouseleave="this.style.color='#2B8080'">
            × Ver todo
          </a>
        )}
      </div>
    </div>
  </div>

  <!-- Product grid -->
  <div style="max-width:1440px;margin:0 auto;padding:32px 24px 72px;">
    {products.length > 0 ? (
      <div class="catalog-grid">
        {products.map((product: any) => <ProductCard product={product} />)}
      </div>
    ) : (
      <div style="text-align:center;padding:100px 32px;">
        <p style="font-family:'Playfair Display',Georgia,serif;font-weight:400;font-size:1.8rem;color:#888;margin-bottom:8px;">Sin resultados</p>
        <p style="font-size:13px;color:#aaa;margin-bottom:24px;">Prueba con otra categoría o término de búsqueda</p>
        <a href="/tienda" style="font-size:12px;font-weight:800;letter-spacing:0.1em;text-transform:uppercase;color:#2B8080;text-decoration:none;border-bottom:2px solid #2B8080;padding-bottom:2px;">
          Ver toda la colección
        </a>
      </div>
    )}
  </div>

</StoreLayout>

<style>
  .catalog-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  @media (max-width: 1100px) {
    .catalog-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 700px) {
    .catalog-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  }
</style>
