---
interface Props {
  product: {
    id: string;
    name: string;
    slug: string;
    price: number;
    compare_at_price?: number;
    images: string[];
    stock: number;
    featured?: boolean;
  };
}

const { product } = Astro.props;
const mainImage = product.images?.[0] || '/placeholder.jpg';
const isOnSale = product.compare_at_price && product.compare_at_price > product.price;
const isOutOfStock = product.stock === 0;
---

<a href={`/tienda/${product.slug}`} class="group block">
  <div class="relative overflow-hidden rounded-xl bg-stone-100 aspect-square mb-3">
    <img
      src={mainImage}
      alt={product.name}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
    {isOutOfStock && (
      <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
        <span class="bg-white text-stone-700 text-xs font-semibold px-3 py-1 rounded-full">Agotado</span>
      </div>
    )}
    {isOnSale && !isOutOfStock && (
      <div class="absolute top-3 left-3">
        <span class="bg-red-500 text-white text-xs font-bold px-2 py-1 rounded-full">OFERTA</span>
      </div>
    )}
  </div>
  <div>
    <h3 class="font-medium text-stone-800 group-hover:text-amber-700 transition-colors">{product.name}</h3>
    <div class="flex items-center gap-2 mt-1">
      <span class="font-bold text-stone-900">{product.price.toFixed(2)}€</span>
      {isOnSale && (
        <span class="text-stone-400 line-through text-sm">{product.compare_at_price!.toFixed(2)}€</span>
      )}
    </div>
  </div>
</a>
